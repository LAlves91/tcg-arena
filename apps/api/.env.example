# Copy to apps/api/.env or export in your shell before `nx serve api`.
# Schema is validated at boot — missing required vars fail fast.

NODE_ENV=development
PORT=3333
LOG_LEVEL=info
WEB_ORIGIN=http://localhost:4200
DISCORD_ACTIVITY_ORIGIN=https://YOUR_CLIENT_ID.discordsays.com
DATABASE_URL=postgresql://tcg:tcg@localhost:5432/tcg_arena?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_REDIRECT_URI=http://localhost:4200/auth/discord/callback

# Auth tokens — JWT_SECRET must be at least 32 chars.
JWT_SECRET=dev-only-secret-please-change-me-32+chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
MAGIC_LINK_TTL_SECONDS=900
